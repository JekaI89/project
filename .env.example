APP_NAME=Product
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost:8080
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Internal MySQL — users, settings, prefs (Laravel owns this)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=product_app
DB_USERNAME=product
DB_PASSWORD=product

# Product ERP MySQL (source of truth). Local Docker defaults after scripts/db-setup.ps1:
PRODUCT_DB_HOST=mysql
PRODUCT_DB_PORT=3306
PRODUCT_DB_DATABASE=product
PRODUCT_DB_USERNAME=product
PRODUCT_DB_PASSWORD=product
PRODUCT_DB_CHARSET=utf8mb4
# true = allow CALL of mutating SP (save, move, status)
PRODUCT_DB_ALLOW_WRITE=true

# Live remote example (Product.ini):
# PRODUCT_DB_HOST=78.107.240.193
# PRODUCT_DB_PORT=33066


SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=product_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# FTP — structured file catalogs (mirrors Delphi Dir_Catalog_*)
FTP_HOST=
FTP_PORT=21
FTP_USERNAME=
FTP_PASSWORD=
FTP_ROOT=/files_product
FTP_PASSIVE=true
FTP_SSL=false

# Catalog relative paths under FTP_ROOT (same idea as Product.ini)
CATALOG_IMG=Img
CATALOG_FILE=Files
CATALOG_ZAKAZ=Zakaz
CATALOG_FINANCE=Finance
CATALOG_ROUTING=Routing

# Absolute path to Delphi photo catalog (Dir_Catalog_Img / files_product)
# Windows share example: E:\files_product  or  \\server\files_product
# Docker: mount share to /mnt/files_product and set PRODUCT_IMG_PATH=/mnt/files_product
PRODUCT_IMG_PATH=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@product.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
